# This frontend reads its config from localStorage (see the in-app
# Configuration screen), so it does NOT use a .env file. This file exists
# only as a reference for the BACKEND server described in SETUP_GUIDE.md.

# From https://developers.tiktok.com/ -> your app -> Basic information
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Comma-separated list of origins that may call your backend
FRONTEND_ORIGIN=http://localhost:4200

PORT=3000
