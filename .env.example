# TikTok API Configuration
# Obtain these from https://developers.tiktok.com/

# TikTok Application Client ID
TIKTOK_CLIENT_ID=your_client_id_here

# TikTok Application Client Secret (Backend only - never expose in frontend!)
TIKTOK_CLIENT_SECRET=your_client_secret_here

# OAuth Redirect URI (must match TikTok Developer Console)
REDIRECT_URI=http://localhost:4200

# Frontend URL (used in backend CORS configuration)
FRONTEND_URL=http://localhost:4200

# Backend Server Port
PORT=3000

# Environment (development or production)
NODE_ENV=development

# Optional: API Base URL (defaults to TikTok's official URL)
# TIKTOK_API_BASE=https://open.tiktokapis.com/v1
